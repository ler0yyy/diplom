FLASK_ENV=development
SECRET_KEY=dev-secret-change-me
JWT_SECRET_KEY=dev-jwt-secret-change-me
CORS_ORIGINS=*

# Server port (default: 5000). On macOS, port 5000 may be used by Control Center.
PORT=5000

# Recommended on Windows: use separate vars (ASCII password only!)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=pollpoint

# Windows + Cyrillic folder path: use pg8000 (default on Windows)
DB_DRIVER=pg8000

# Alternative: full URL
# DATABASE_URL=postgresql+pg8000://postgres:postgres@127.0.0.1:5432/pollpoint
